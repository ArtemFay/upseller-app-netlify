# Upseller — единый сервер всего сайта (Инвент, Подбор, Приемка, События).
# Локально: cp .env.example .env, заполнить минимум — AUTH_DISABLED, SESSION_SECRET, GOOGLE_SERVICE_ACCOUNT_KEY_PATH.
# На VPS: cp в /opt/upseller/server/.env (chmod 600), AUTH_DISABLED не выставлять.

# === Server ===
PORT=3010
HOST=127.0.0.1
# Локально — относительно server/. На VPS — /var/lib/upseller (отдельный volume).
DATA_DIR=./data
# Локально http: COOKIE_SECURE=false. На https-проде — true (или удалить переменную).
COOKIE_SECURE=false

# === Локальный режим без Google-логина ===
# true → авторизация отключена, все запросы идут как dev@local (admin).
# Используется ТОЛЬКО локально. На VPS должно быть false (или переменная отсутствует).
AUTH_DISABLED=true

# === Google Sheets API — единый сервис-аккаунт ===
# Один auth-механизм для всех модулей. Сервис-аккаунт `sheets-bot@sheet-ai-491412.iam.gserviceaccount.com`
# уже расшарен на UPSELLER, ПОДБОРЫ АПСЕЛЛЕР, Планшет подборщика, ИНВЕНТ.
#
# Локально: путь к JSON-ключу на диске пользователя.
# На VPS: положить ключ в /etc/upseller/sheets-bot-sa.json (chmod 600), указать путь здесь.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=C:\Users\Psgl2\.claude\sheets-bot-sa.json
# Альтернатива (если не хочется отдельного файла) — полное содержимое JSON одной строкой:
# GOOGLE_SERVICE_ACCOUNT_KEY=

# === Google Identity Services — логин пользователей в web (popup) ===
# Нужно ТОЛЬКО для прода (когда AUTH_DISABLED=false). JS-origin allowlist в Google Cloud
# должен включать прод-URL (https://82-97-249-207.sslip.io).
GOOGLE_WEB_CLIENT_ID=

# === Session JWT signing key (≥ 32 chars) ===
# Используется и в проде, и в dev (JWT нужен даже с AUTH_DISABLED для cookie-сессии).
# Сгенерировать: openssl rand -hex 32
SESSION_SECRET=replace-with-random-32-plus-chars-locally

# === Bootstrap admin email ===
# Первый админ whitelist'а на проде. Локально с AUTH_DISABLED не используется.
ADMIN_EMAIL=psgl2007@gmail.com

# === Spreadsheet IDs ===
SPREADSHEET_ID=1yORm5SHJlBXrJx2JwutCJXKLQjqqFozVxZqV0hu4a8Q
UPSELLER_ID=1yORm5SHJlBXrJx2JwutCJXKLQjqqFozVxZqV0hu4a8Q
PODBORY_ID=1mTVGXZgLh93O4lTTSXVr0cZ9Eu34urDm3jFJioorciM
INVENT_SPREADSHEET_ID=1xHs4IWslef6agbB_QM6fPuwqR66kEHdBni83R_K3gmM
