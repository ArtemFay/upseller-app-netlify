{
  "name": "web-podbor",
  "version": "0.1.0",
  "private": true,
  "description": "Локальный MVP веб-планшета подборщика. Порт LoadClientData из KorobyService_2 в Node.js.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon --watch server.js --watch lib --watch .env --ext js,json server.js",
    "sync": "browser-sync start --proxy localhost:3000 --port 3001 --files \"public/**/*\" \"lib/**/*\" \"server.js\" --no-open --no-notify --reload-delay 600",
    "dev": "concurrently -k -n server,browser -c blue,magenta \"npm:server\" \"npm:sync\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
