# Local dependencies and build output
node_modules/

# Local secrets — never commit
.env
.env.local
**/.env
**/.env.local

# Local server runtime (whitelist users.json — данные, не код).
# .env уже покрыт паттерном **/.env выше.
server/data/

# Sync engine runtime: очереди, locks, архив завершённых заявок.
# data/users.json — whitelist, остаётся в git (см. git ls-files data/).
data/podbor/

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/

# Logs
*.log

# MCP browser-tool артефакты (chrome-devtools / playwright snapshots)
.playwright-mcp/

# PNG в корне репо — не должны коммититься (тестовые скриншоты).
# Скриншоты для документации — кладите в archive/ или модульный docs/.
/*.png

# Скриншоты диагностики (chrome-devtools captures, bug-reports)
data/*.png

# Локальные diagnostic-скрипты (вне scope production deploy)
scripts/test-*.mjs
scripts/verify-*.mjs
scripts/inject-*.mjs
scripts/find-*.mjs
scripts/cleanup-*.mjs
